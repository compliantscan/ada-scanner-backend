# ADA Scanner backend environment example
# Copy this to .env and fill values. Never commit real secrets.

PORT=3000

# Supabase persistence and paid entitlements
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
# Required for paid reports, subscription lookup, scan claiming, and AI-fix cache writes.
SUPABASE_SERVICE_ROLE_KEY=

# Resend email delivery
RESEND_API_KEY=
RESEND_FROM=no-reply@example.com

# Claude Haiku paid-report fixes
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Stripe payments
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_AGENCY=price_...

# Frontend base URL (used in Stripe redirect URLs)
FRONTEND_URL=http://localhost:3000
